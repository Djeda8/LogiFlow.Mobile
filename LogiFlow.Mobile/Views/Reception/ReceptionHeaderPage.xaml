<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LogiFlow.Mobile.ViewModels.Reception"
             xmlns:icons="clr-namespace:LogiFlow.Mobile.Resources.Icons"
             xmlns:local="clr-namespace:LogiFlow.Mobile.Extensions"
             x:Class="LogiFlow.Mobile.Views.Reception.ReceptionHeaderPage"
             x:DataType="vm:ReceptionHeaderViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource PageBackground}"
             Title="{local:Translate Key=ReceptionHeaderTitle}">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER con botón Ask AI ===== -->
        <Grid Grid.Row="0" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <Label Grid.Column="0">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Logi" FontSize="22" TextColor="{DynamicResource PrimaryColor}"/>
                            <Span Text="Flow" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource PrimaryColor}"/>
                            <Span Text=" · " FontSize="22" TextColor="{DynamicResource SecondaryText}"/>
                            <Span Text="{local:Translate Key=ReceptionHeaderTitle}" FontSize="22" TextColor="{DynamicResource PrimaryText}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Button Grid.Column="1"
                        Text="{local:Translate Key=AiChatAskButton}"
                        Command="{Binding OpenAiChatCommand}"
                        FontFamily="RobotoMedium"
                        FontSize="13"
                        Padding="12,6"
                        CornerRadius="16"
                        BackgroundColor="{DynamicResource PrimaryColor}"
                        TextColor="{DynamicResource IconTextDefault}"
                        VerticalOptions="Center"/>
            </Grid>

            <Label Grid.Row="1"
                   Text="{Binding ReceptionNumber}"
                   Style="{StaticResource SecondaryTextStyle}"/>

            <BoxView Grid.Row="2"
                     HeightRequest="1"
                     BackgroundColor="{DynamicResource Divider}"
                     Margin="0,4,0,0"/>
        </Grid>

        <!-- ===== CONTENT ===== -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- ===== Reception info (read only) ===== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                                   Source="{icons:AppIcon Icon=Receipt, Color={StaticResource PrimaryColor}}"
                                   WidthRequest="22" HeightRequest="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{local:Translate Key=ReceptionHeaderSectionInfo}"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        </Grid>

                        <!-- Reception Number -->
                        <Label Text="{local:Translate Key=ReceptionHeaderNumber}"
                               Style="{StaticResource FieldLabelStyle}"/>
                        <Entry Text="{Binding ReceptionNumber}"
                               IsReadOnly="True"
                               Style="{StaticResource PrimaryEntryStyle}"/>

                        <!-- Flow Type -->
                        <Label Text="{local:Translate Key=ReceptionHeaderFlowType}"
                               Style="{StaticResource FieldLabelStyle}"/>
                        <Entry Text="{Binding FlowType}"
                               IsReadOnly="True"
                               Style="{StaticResource PrimaryEntryStyle}"/>

                        <!-- Delivery Note -->
                        <Label Text="{local:Translate Key=ReceptionHeaderDeliveryNote}"
                               Style="{StaticResource FieldLabelStyle}"/>
                        <Entry Text="{Binding DeliveryNote}"
                               IsReadOnly="True"
                               Style="{StaticResource PrimaryEntryStyle}"/>

                        <!-- Expected Date -->
                        <Label Text="{local:Translate Key=ReceptionHeaderExpectedDate}"
                               Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker Date="{Binding ExpectedDate}"
                                    IsEnabled="False"
                                    TextColor="{DynamicResource PrimaryText}"/>

                    </VerticalStackLayout>
                </Border>

                <!-- ===== Sender / Recipient (editable) ===== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                                   Source="{icons:AppIcon Icon=LocalShipping, Color={StaticResource PrimaryColor}}"
                                   WidthRequest="22" HeightRequest="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{local:Translate Key=ReceptionHeaderSectionParties}"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        </Grid>

                        <!-- Sender -->
                        <Label Text="{local:Translate Key=ReceptionHeaderSender}"
                               Style="{StaticResource FieldLabelStyle}"/>
                        <Picker ItemsSource="{Binding AvailableSenders}"
                                SelectedItem="{Binding Sender}"
                                IsEnabled="{Binding IsNotBusy}"/>

                        <!-- Recipient -->
                        <Label Text="{local:Translate Key=ReceptionHeaderRecipient}"
                               Style="{StaticResource FieldLabelStyle}"/>
                        <Picker ItemsSource="{Binding AvailableRecipients}"
                                SelectedItem="{Binding Recipient}"
                                IsEnabled="{Binding IsNotBusy}"/>

                    </VerticalStackLayout>
                </Border>

                <!-- ===== Observations ===== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                                   Source="{icons:AppIcon Icon=Info, Color={StaticResource PrimaryColor}}"
                                   WidthRequest="22" HeightRequest="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{local:Translate Key=ReceptionHeaderSectionObservations}"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        </Grid>

                        <Label Text="{local:Translate Key=ReceptionHeaderObservations}"
                               Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource EntryBorderStyle}">
                            <Editor Text="{Binding Observations}"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="80"
                                    Style="{StaticResource PrimaryEntryStyle}"
                                    IsEnabled="{Binding IsNotBusy}"/>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ===== ERROR ===== -->
        <Grid Grid.Row="2"
              ColumnSpacing="8"
              IsVisible="{Binding HasError}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0"
                   Source="{icons:AppIcon Icon=ErrorOutline, Color={StaticResource ErrorColor}}"
                   WidthRequest="24" HeightRequest="24"/>
            <Label Grid.Column="1"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorTextStyle}"/>
        </Grid>

        <!-- ===== BUTTONS ===== -->
        <Button Grid.Row="3"
                Text="{local:Translate Key=ReceptionHeaderContinue}"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding ContinueCommand}"
                IsEnabled="{Binding IsNotBusy}"/>

        <Grid Grid.Row="4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Text="{local:Translate Key=CommonBack}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding GoBackCommand}"
                    IsEnabled="{Binding IsNotBusy}"/>
            <ActivityIndicator Grid.Column="1"
                               IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               VerticalOptions="Center"/>
        </Grid>

    </Grid>
</ContentPage>
