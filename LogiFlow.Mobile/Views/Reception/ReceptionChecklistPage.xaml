<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LogiFlow.Mobile.ViewModels.Reception"
             xmlns:icons="clr-namespace:LogiFlow.Mobile.Resources.Icons"
             xmlns:local="clr-namespace:LogiFlow.Mobile.Extensions"
             x:Class="LogiFlow.Mobile.Views.Reception.ReceptionChecklistPage"
             x:DataType="vm:ReceptionChecklistViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource PageBackground}"
             Title="{local:Translate Key=ReceptionChecklistTitle}">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Logi" FontSize="22" TextColor="{DynamicResource PrimaryColor}"/>
                        <Span Text="Flow" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource PrimaryColor}"/>
                        <Span Text=" · " FontSize="22" TextColor="{DynamicResource SecondaryText}"/>
                        <Span Text="{local:Translate Key=ReceptionChecklistTitle}" FontSize="22" TextColor="{DynamicResource PrimaryText}"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label Text="{Binding ReceptionNumber}"
                   Style="{StaticResource SecondaryTextStyle}"/>
            <BoxView HeightRequest="1" BackgroundColor="{DynamicResource Divider}" Margin="0,4,0,0"/>
        </VerticalStackLayout>

        <!-- ===== CONTENT ===== -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- ===== Checklist items ===== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                                   Source="{icons:AppIcon Icon=Checklist, Color={StaticResource PrimaryColor}}"
                                   WidthRequest="22" HeightRequest="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{local:Translate Key=ReceptionChecklistSectionTitle}"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        </Grid>

                        <Label Text="{local:Translate Key=ReceptionChecklistInstruction}"
                               Style="{StaticResource SecondaryTextStyle}"/>

                        <CollectionView ItemsSource="{Binding ChecklistItems}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChecklistItemViewModel">
                                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,4">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsChecked}"
                                                      Color="{DynamicResource PrimaryColor}"
                                                      VerticalOptions="Center"/>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Description}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

                <!-- ===== Completion status ===== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0"
                               WidthRequest="24" HeightRequest="24"
                               VerticalOptions="Center">
                            <Image.Triggers>
                                <DataTrigger TargetType="Image"
                                             Binding="{Binding AllItemsChecked}"
                                             Value="True">
                                    <Setter Property="Source"
                                            Value="{icons:AppIcon Icon=CheckCircle, Color={StaticResource SuccessColor}}"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Image"
                                             Binding="{Binding AllItemsChecked}"
                                             Value="False">
                                    <Setter Property="Source"
                                            Value="{icons:AppIcon Icon=ErrorOutline, Color={StaticResource WarningColor}}"/>
                                </DataTrigger>
                            </Image.Triggers>
                        </Image>
                        <Label Grid.Column="1"
                               VerticalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding AllItemsChecked}"
                                             Value="True">
                                    <Setter Property="Text"
                                            Value="{local:Translate Key=ReceptionChecklistComplete}"/>
                                    <Setter Property="TextColor"
                                            Value="{DynamicResource SuccessColor}"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding AllItemsChecked}"
                                             Value="False">
                                    <Setter Property="Text"
                                            Value="{local:Translate Key=ReceptionChecklistPending}"/>
                                    <Setter Property="TextColor"
                                            Value="{DynamicResource WarningColor}"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ===== ERROR ===== -->
        <Grid Grid.Row="2"
              ColumnSpacing="8"
              IsVisible="{Binding HasError}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0"
                   Source="{icons:AppIcon Icon=ErrorOutline, Color={StaticResource ErrorColor}}"
                   WidthRequest="24" HeightRequest="24"/>
            <Label Grid.Column="1"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorTextStyle}"/>
        </Grid>

        <!-- ===== CONTINUE BUTTON ===== -->
        <Button Grid.Row="3"
                Text="{local:Translate Key=ReceptionChecklistContinue}"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding ContinueCommand}"
                IsEnabled="{Binding AllItemsChecked}"/>

        <!-- ===== BACK + LOADING ===== -->
        <Grid Grid.Row="4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Text="{local:Translate Key=CommonBack}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding GoBackCommand}"
                    IsEnabled="{Binding IsNotBusy}"/>
            <ActivityIndicator Grid.Column="1"
                               IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               VerticalOptions="Center"/>
        </Grid>

    </Grid>
</ContentPage>
