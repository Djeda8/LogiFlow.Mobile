<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LogiFlow.Mobile.ViewModels.Reception"
             xmlns:icons="clr-namespace:LogiFlow.Mobile.Resources.Icons"
             xmlns:local="clr-namespace:LogiFlow.Mobile.Extensions"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="LogiFlow.Mobile.Views.Reception.ReceptionStartPage"
             x:DataType="vm:ReceptionStartViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource PageBackground}"
             Title="{local:Translate Key=ReceptionStartTitle}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Logi" FontSize="22" TextColor="{DynamicResource PrimaryColor}"/>
                        <Span Text="Flow" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource PrimaryColor}"/>
                        <Span Text=" · " FontSize="22" TextColor="{DynamicResource SecondaryText}"/>
                        <Span Text="{local:Translate Key=ReceptionStartTitle}" FontSize="22" TextColor="{DynamicResource PrimaryText}"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <BoxView HeightRequest="1" BackgroundColor="{DynamicResource Divider}" Margin="0,4,0,0"/>
        </VerticalStackLayout>

        <!-- ===== SCAN FIELD ===== -->
        <Label Grid.Row="1"
               Text="{local:Translate Key=ReceptionStartNumberLabel}"
               Style="{StaticResource FieldLabelStyle}"/>

        <Border Grid.Row="2" Style="{StaticResource EntryBorderStyle}">
            <Grid ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="48"/>
                </Grid.ColumnDefinitions>

                <!-- Camera button -->
                <ImageButton Grid.Column="0"
                             Source="{icons:AppIcon Icon=QrCodeScanner, Color={StaticResource PrimaryColor}}"
                             WidthRequest="48"
                             HeightRequest="48"
                             Padding="8"
                             BackgroundColor="Transparent"
                             Command="{Binding OpenCameraCommand}"
                             IsEnabled="{Binding IsNotBusy}"/>

                <!-- Entry -->
                <Entry Grid.Column="1"
                       Placeholder="{local:Translate Key=ReceptionStartNumberPlaceholder}"
                       Text="{Binding ReceptionNumber}"
                       Style="{StaticResource PrimaryEntryStyle}"
                       IsEnabled="{Binding IsNotBusy}"
                       ReturnType="Go"
                       ReturnCommand="{Binding ScanReceptionCommand}"/>

                <!-- Confirm button -->
                <ImageButton Grid.Column="2"
                             Source="{icons:AppIcon Icon=CheckCircle, Color={StaticResource PrimaryColor}}"
                             WidthRequest="48"
                             HeightRequest="48"
                             Padding="8"
                             BackgroundColor="Transparent"
                             Command="{Binding ScanReceptionCommand}"
                             IsEnabled="{Binding IsNotBusy}"/>
            </Grid>
        </Border>

        <!-- ===== RECEPTION INFO (visible after load) ===== -->
        <Border Grid.Row="3"
                Style="{StaticResource SectionCardStyle}"
                IsVisible="{Binding ReceptionLoaded}">
            <VerticalStackLayout Spacing="8">

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="{icons:AppIcon Icon=Receipt, Color={StaticResource PrimaryColor}}"
                           WidthRequest="20" HeightRequest="20"/>
                    <Label Grid.Column="1"
                           Text="{Binding ReceptionNumber}"
                           Style="{StaticResource BodyTextStyle}"
                           FontAttributes="Bold"/>
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="{icons:AppIcon Icon=Info, Color={StaticResource PrimaryColor}}"
                           WidthRequest="20" HeightRequest="20"/>
                    <Label Grid.Column="1"
                           Text="{Binding FlowTypeDisplay}"
                           Style="{StaticResource SecondaryTextStyle}"/>
                </Grid>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="{icons:AppIcon Icon=CheckCircle, Color={StaticResource PrimaryColor}}"
                           WidthRequest="20" HeightRequest="20"/>
                    <Label Grid.Column="1"
                           Text="{Binding StatusDisplay}"
                           Style="{StaticResource SecondaryTextStyle}"/>
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- ===== ERROR ===== -->
        <Grid Grid.Row="4"
              ColumnSpacing="8"
              IsVisible="{Binding HasError}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0"
                   Source="{icons:AppIcon Icon=ErrorOutline, Color={StaticResource ErrorColor}}"
                   WidthRequest="24" HeightRequest="24"/>
            <Label Grid.Column="1"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorTextStyle}"/>
        </Grid>

        <!-- ===== SPACER ===== -->
        <BoxView Grid.Row="5" BackgroundColor="Transparent"/>

        <!-- ===== CONFIRM BUTTON ===== -->
        <Button Grid.Row="6"
        Text="{local:Translate Key=ReceptionStartScanButton}"
        Style="{StaticResource PrimaryButtonStyle}"
        Command="{Binding ScanReceptionCommand}"
        IsEnabled="{Binding IsNotBusy}"
        IsVisible="{Binding ReceptionLoaded, Converter={StaticResource InverseBoolConverter}}"/>

        <Button Grid.Row="6"
        Text="{local:Translate Key=ReceptionStartContinue}"
        Style="{StaticResource PrimaryButtonStyle}"
        Command="{Binding ContinueCommand}"
        IsEnabled="{Binding IsNotBusy}"
        IsVisible="{Binding ReceptionLoaded}"/>

        <!-- ===== BACK + LOADING ===== -->
        <Grid Grid.Row="7" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Text="{local:Translate Key=CommonBack}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding GoBackCommand}"
                    IsEnabled="{Binding IsNotBusy}"/>
            <ActivityIndicator Grid.Column="1"
                               IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               VerticalOptions="Center"/>
        </Grid>

    </Grid>
</ContentPage>
