<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LogiFlow.Mobile.ViewModels.Reception"
             xmlns:icons="clr-namespace:LogiFlow.Mobile.Resources.Icons"
             xmlns:local="clr-namespace:LogiFlow.Mobile.Extensions"
             xmlns:dto="clr-namespace:LogiFlow.Mobile.DTOs"
             x:Class="LogiFlow.Mobile.Views.Reception.ReceptionItemsPage"
             x:DataType="vm:ReceptionItemsViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource PageBackground}"
             Title="{local:Translate Key=ReceptionItemsTitle}">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Logi" FontSize="22" TextColor="{DynamicResource PrimaryColor}"/>
                        <Span Text="Flow" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource PrimaryColor}"/>
                        <Span Text=" · " FontSize="22" TextColor="{DynamicResource SecondaryText}"/>
                        <Span Text="{local:Translate Key=ReceptionItemsTitle}" FontSize="22" TextColor="{DynamicResource PrimaryText}"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label Text="{Binding ReceptionNumber}"
                   Style="{StaticResource SecondaryTextStyle}"/>
            <BoxView HeightRequest="1" BackgroundColor="{DynamicResource Divider}" Margin="0,4,0,0"/>
        </VerticalStackLayout>

        <!-- ===== CONTENT ===== -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- ===== Summary totals ===== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                                   Source="{icons:AppIcon Icon=CheckCircle, Color={StaticResource SuccessColor}}"
                                   WidthRequest="22" HeightRequest="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{local:Translate Key=ReceptionItemsSectionSummary}"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        </Grid>

                        <!-- Total items -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Text="{local:Translate Key=ReceptionItemsTotalItems}"
                                   Style="{StaticResource FieldLabelStyle}"/>
                            <Label Grid.Column="1"
                                   Text="{Binding TotalItems}"
                                   Style="{StaticResource BodyTextStyle}"
                                   FontAttributes="Bold"/>
                        </Grid>

                        <!-- Total quantity -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Text="{local:Translate Key=ReceptionItemsTotalQuantity}"
                                   Style="{StaticResource FieldLabelStyle}"/>
                            <Label Grid.Column="1"
                                   Text="{Binding TotalQuantity}"
                                   Style="{StaticResource BodyTextStyle}"
                                   FontAttributes="Bold"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ===== Generated items list ===== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                                   Source="{icons:AppIcon Icon=ViewList, Color={StaticResource PrimaryColor}}"
                                   WidthRequest="22" HeightRequest="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{local:Translate Key=ReceptionItemsSectionList}"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        </Grid>

                        <CollectionView ItemsSource="{Binding GeneratedItems}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="dto:ItemDto">
                                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,4">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Image Grid.Column="0"
                                                   Source="{icons:AppIcon Icon=Inventory2, Color={StaticResource PrimaryColor}}"
                                                   WidthRequest="20" HeightRequest="20"
                                                   VerticalOptions="Center"/>

                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="{Binding ItemCode}"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       FontAttributes="Bold"/>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Grid.Column="0"
                                                           Source="{icons:AppIcon Icon=Inventory2, Color={StaticResource SecondaryText}}"
                                                           WidthRequest="14" HeightRequest="14"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding Article}"
                                                           Style="{StaticResource SecondaryTextStyle}"/>
                                                </Grid>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Grid.Column="0"
                                                           Source="{icons:AppIcon Icon=LocationOn, Color={StaticResource SecondaryText}}"
                                                           WidthRequest="14" HeightRequest="14"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding Location}"
                                                           Style="{StaticResource SecondaryTextStyle}"/>
                                                </Grid>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Grid.Column="0"
                                                           Source="{icons:AppIcon Icon=Tag, Color={StaticResource SecondaryText}}"
                                                           WidthRequest="14" HeightRequest="14"
                                                           VerticalOptions="Center"/>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding Quantity}"
                                                           Style="{StaticResource SecondaryTextStyle}"/>
                                                </Grid>
                                            </VerticalStackLayout>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ===== ERROR ===== -->
        <Grid Grid.Row="2"
              ColumnSpacing="8"
              IsVisible="{Binding HasError}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0"
                   Source="{icons:AppIcon Icon=ErrorOutline, Color={StaticResource ErrorColor}}"
                   WidthRequest="24" HeightRequest="24"/>
            <Label Grid.Column="1"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorTextStyle}"/>
        </Grid>

        <!-- ===== FINISH + LOADING ===== -->
        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Text="{local:Translate Key=ReceptionItemsFinish}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding FinishCommand}"
                    IsEnabled="{Binding IsNotBusy}"/>
            <ActivityIndicator Grid.Column="1"
                               IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               VerticalOptions="Center"/>
        </Grid>

    </Grid>
</ContentPage>
