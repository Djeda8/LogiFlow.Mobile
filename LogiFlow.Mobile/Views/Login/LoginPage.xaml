<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LogiFlow.Mobile.Views.Login.LoginPage"
             xmlns:vm="clr-namespace:LogiFlow.Mobile.ViewModels.Login"
             xmlns:icons="clr-namespace:LogiFlow.Mobile.Resources.Icons"
             xmlns:local="clr-namespace:LogiFlow.Mobile.Extensions"
             x:DataType="vm:LoginViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource PageBackground}"
             Title="{local:Translate Key=LoginTitle}">
    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="350"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== Logo / App name ========== -->
        <Label Grid.Row="0" HorizontalOptions="Center" VerticalOptions="Center">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Logi" FontAttributes="None" FontSize="32" TextColor="{DynamicResource PrimaryColor}" />
                    <Span Text="Flow" FontAttributes="Bold" FontSize="36" TextColor="{DynamicResource PrimaryColor}" />
                </FormattedString>
            </Label.FormattedText>
        </Label>

        <!-- ========== Username ========== -->
        <Border Grid.Row="1"
                Style="{StaticResource EntryBorderStyle}">
            <Border.Triggers>
                <DataTrigger TargetType="Border"
                     Binding="{Binding UsernameHasError}"
                     Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource ErrorColor}"/>
                </DataTrigger>
            </Border.Triggers>
            <Grid ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="{icons:AppIcon Icon=Person, Color={StaticResource PrimaryColor}}" WidthRequest="24" HeightRequest="24" />
                <Entry Grid.Column="1"
                       Placeholder="{local:Translate Key=LoginUsernamePlaceholder}"
                       Text="{Binding Username}"
                       Style="{StaticResource PrimaryEntryStyle}"
                       IsEnabled="{Binding IsNotBusy}" />
            </Grid>
        </Border>

        <!-- ========== Password ========== -->
        <Border Grid.Row="2"
                Style="{StaticResource EntryBorderStyle}">
            <Border.Triggers>
                <DataTrigger TargetType="Border"
                     Binding="{Binding PasswordHasError}"
                     Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource ErrorColor}"/>
                </DataTrigger>
            </Border.Triggers>
            <Grid ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="{icons:AppIcon Icon=Lock, Color={StaticResource PrimaryColor}}" WidthRequest="24" HeightRequest="24" />
                <Entry Grid.Column="1"
                       Placeholder="{local:Translate Key=LoginPasswordPlaceholder}"
                       Text="{Binding Password}"
                       Style="{StaticResource PrimaryEntryStyle}"
                       IsEnabled="{Binding IsNotBusy}" />
            </Grid>
        </Border>

        <!-- ========== Error message ========== -->
        <Grid Grid.Row="3" ColumnSpacing="8" IsVisible="{Binding HasError}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="{icons:AppIcon Icon=ErrorOutline, Color={StaticResource ErrorColor}}" />
            <Label Grid.Column="1" Text="{Binding ErrorMessage}" Style="{StaticResource ErrorTextStyle}" />
        </Grid>

        <!-- ========== Login button ========== -->
        <Button Grid.Row="4"
                Text="{local:Translate Key=LoginButton}"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding LoginCommand}"
                IsEnabled="{Binding CanLogin}" />

        <!-- ========== Loading ========== -->
        <ActivityIndicator Grid.Row="5"
                           IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="Center" />
    </Grid>
</ContentPage>
