<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Entry estándar -->
    <Style x:Key="PrimaryEntryStyle" TargetType="Entry">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryText}" />
        <Setter Property="BackgroundColor" Value="{StaticResource LightPrimary}" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!-- Entry con error -->
    <Style x:Key="ErrorEntryStyle" TargetType="Entry" BasedOn="{StaticResource PrimaryEntryStyle}">
        <Setter Property="TextColor" Value="{StaticResource ErrorColor}"/>
        <Setter Property="BackgroundColor" Value="#FEE2E2" />
    </Style>

</ResourceDictionary>