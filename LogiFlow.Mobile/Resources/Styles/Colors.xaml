<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Colores base -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="DarkPrimary">#1E40AF</Color>
    <Color x:Key="LightPrimary">#C5CAE9</Color>
    <Color x:Key="AccentColor">#975E5E</Color>

    <!-- Texto -->
    <Color x:Key="PrimaryText">#111827</Color>
    <Color x:Key="SecondaryText">#757575</Color>
    <Color x:Key="IconTextDefault">#FFFFFF</Color>
    <Color x:Key="Divider">#E5E7EB</Color>
    
    <!-- Estados -->
    <Color x:Key="ErrorColor">#DC2626</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>

    <Color x:Key="DisabledColor">#9CA3AF</Color>
    
</ResourceDictionary>

