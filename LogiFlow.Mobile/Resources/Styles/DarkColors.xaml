<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="LogiFlow.Mobile.Resources.Styles.DarkColors">

    <!-- Colores base -->
    <Color x:Key="PrimaryColor">#60A5FA</Color>
    <Color x:Key="DarkPrimary">#3B82F6</Color>
    <Color x:Key="LightPrimary">#1E3A5F</Color>
    <Color x:Key="AccentColor">#C49A9A</Color>

    <!-- Texto -->
    <Color x:Key="PrimaryText">#F9FAFB</Color>
    <Color x:Key="SecondaryText">#9CA3AF</Color>
    <Color x:Key="IconTextDefault">#FFFFFF</Color>
    <Color x:Key="Divider">#374151</Color>

    <!-- Estados -->
    <Color x:Key="ErrorColor">#F87171</Color>
    <Color x:Key="WarningColor">#FCD34D</Color>
    <Color x:Key="SuccessColor">#4ADE80</Color>
    <Color x:Key="DisabledColor">#6B7280</Color>

    <!-- Theming semántico -->
    <Color x:Key="PageBackground">#0F172A</Color>
    <Color x:Key="CardBackground">#1E293B</Color>
    <Color x:Key="ErrorEntryBackground">#450A0A</Color>

</ResourceDictionary>
