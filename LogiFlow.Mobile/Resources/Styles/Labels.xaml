<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Título de pantalla -->
    <Style x:Key="TitleLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{DynamicResource  PrimaryText}" />
    </Style>

    <!-- Título de sección dentro de card -->
    <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{DynamicResource  PrimaryText}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- Label de campo / placeholder -->
    <Style x:Key="FieldLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{DynamicResource  PrimaryText}" />
    </Style>

    <!-- Texto principal / body -->
    <Style x:Key="BodyTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{DynamicResource  PrimaryText}" />
    </Style>

    <!-- Texto secundario / hint / descripción -->
    <Style x:Key="SecondaryTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{DynamicResource  SecondaryText}" />
    </Style>

    <!-- Texto de error / validación -->
    <Style x:Key="ErrorTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="RobotoMedium" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="TextColor" Value="{DynamicResource  ErrorColor}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

</ResourceDictionary>
