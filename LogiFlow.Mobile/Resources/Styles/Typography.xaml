<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Fuente base por plataforma -->
    <OnPlatform x:Key="AppFontFamily" x:TypeArguments="x:String">
        <On Platform="Android" Value="RobotoRegular"/>
        <On Platform="iOS" Value="System"/>
        <On Platform="MacCatalyst" Value="System"/>
        <On Platform="WinUI" Value="Segoe UI"/>
    </OnPlatform>
</ResourceDictionary>
